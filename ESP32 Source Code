#define MQ135_PIN 34

void setup() {
  Serial.begin(115200);
}

void loop() {

  int airQuality = analogRead(MQ135_PIN);

  Serial.print("Air Quality Value: ");
  Serial.println(airQuality);

  if(airQuality > 2000) {
    Serial.println("Poor Air Quality");
  }
  else {
    Serial.println("Good Air Quality");
  }

  delay(2000);
}
